VITE_CSC_WHATSAPP_NUMBER=91XXXXXXXXXX

# Development-only local workspace bypass.
# Works only in Vite dev mode and skips the server auth gate so you can review UI changes offline.
VITE_ENABLE_OFFLINE_DEV_ACCESS=false

# --- Server-side Supabase (Do not prefix with VITE_) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server-side App Gate / 2FA (Do not prefix with VITE_ or NEXT_PUBLIC_) ---
# Required for secure app access gate. These are read only by Vercel server/API code.
JWT_SECRET=
GATE_SESSION_TTL_MINUTES=15
GATE_SECURITY_CODE_HASH=
GATE_TOTP_SECRET=
GATE_RATE_LIMIT_ATTEMPTS=5
GATE_RATE_LIMIT_WINDOW_MS=600000

# Optional deploy-grade shared rate limit store.
# Vercel KV exposes these automatically; Upstash Redis REST uses the UPSTASH_* names.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional fallback if authenticator is unavailable:
GATE_BACKUP_CODE_HASH=

# Optional plain-code fallback for initial setup only (prefer HASH values above):
# GATE_SECURITY_CODE=
# GATE_BACKUP_CODE=

# Legacy aliases still supported for existing deployments:
# DB_SESSION_SECRET=
# DB_SESSION_TTL_MINUTES=15
# DB_SECURITY_CODE_HASH=
# DB_TOTP_SECRET=
# DB_BACKUP_CODE_HASH=
